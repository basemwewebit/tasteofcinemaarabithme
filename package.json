{
  "name": "tasteofcinemaarabithme",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind build pipeline for Mazaq Cinema WordPress theme",
  "scripts": {
    "dev": "tailwindcss -i ./assets/css/src/style.css -o ./assets/css/style.css --watch",
    "build": "tailwindcss -i ./assets/css/src/style.css -o ./assets/css/style.css --minify"
  },
  "devDependencies": {
    "@fontsource/amiri": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans-arabic": "^5.2.9",
    "@fontsource/tajawal": "^5.2.7",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "impeccable": "^2.1.9"
  }
}
